# Postgres. Neon kullanıyorsan (öneri):
#   DATABASE_URL = "pooled" bağlantı (host içinde -pooler geçer) → uygulama çalışırken
#   DIRECT_URL   = "direct" (havuzsuz) bağlantı → migration + seed için
# Pooler yoksa ikisine de aynı "direct" dizeyi yazabilirsin.
DATABASE_URL="postgresql://user:pass@localhost:5432/zerdemkartal"
DIRECT_URL="postgresql://user:pass@localhost:5432/zerdemkartal"

# Admin JWT imzası
JWT_SECRET="degistir-uzun-rastgele-dizi"

# MCP / servis erişimi için uzun ömürlü token (Faz 3) — JWT'den AYRI tut
ADMIN_TOKEN="degistir-mcp-icin-uzun-token"

# İlk admin kullanıcısı (seed bunu yazar)
ADMIN_EMAIL="merhaba@zerdemkartal.com"
ADMIN_PASSWORD="degistir"

# Google girişi (üretim) — id_token sunucuda doğrulanacak
GOOGLE_CLIENT_ID=""

# Site kökü (canonical/OG mutlak URL'ler)
SITE_URL="https://hermesastroloji.com"

# IndexNow anahtarı (opsiyonel — boşsa ping atlanır). Rastgele 32+ karakter hex önerilir;
# anahtar dosyası /indexnow.txt route'undan otomatik servis edilir.
INDEXNOW_KEY=""

# Masaüstü sürüm yayınları için GitHub reposu (opsiyonel — varsayılan: zerdemkartal/hermes-yayin).
# /indir sayfası buradaki son release'ten sürüm no + notları çeker.
RELEASES_REPO="zerdemkartal/hermes-yayin"

# ————— ÖDEME: iyzico (H2) —————
# Anahtarlar boşken /api/pay/iyzico/* uçları 503 döner (site "dürüst ön sipariş" akışında kalır).
# Sandbox anahtarları: iyzico Sandbox panelinden. Canlı: gerçek üye işyeri onayından sonra.
IYZICO_API_KEY=""
IYZICO_SECRET=""
# Sandbox: https://sandbox-api.iyzipay.com  ·  Canlı: https://api.iyzipay.com
IYZICO_URI="https://sandbox-api.iyzipay.com"

# ————— E-POSTA: Resend (H2) —————
# RESEND_API_KEY boşken e-posta sessizce atlanır (ödeme/callback akışı kırılmaz).
RESEND_API_KEY=""
# Gönderen — domaini Resend'de doğrulanmış olmalı. Test için "Hermes <onboarding@resend.dev>" kullanılabilir.
EMAIL_FROM="Hermes <siparis@hermesastroloji.com>"
