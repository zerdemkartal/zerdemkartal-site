# Postgres. Neon kullanıyorsan (öneri):
#   DATABASE_URL = "pooled" bağlantı (host içinde -pooler geçer) → uygulama çalışırken
#   DIRECT_URL   = "direct" (havuzsuz) bağlantı → migration + seed için
# Pooler yoksa ikisine de aynı "direct" dizeyi yazabilirsin.
DATABASE_URL="postgresql://user:pass@localhost:5432/zerdemkartal"
DIRECT_URL="postgresql://user:pass@localhost:5432/zerdemkartal"

# Admin JWT imzası
JWT_SECRET="degistir-uzun-rastgele-dizi"

# MCP / servis erişimi için uzun ömürlü token (Faz 3) — JWT'den AYRI tut
ADMIN_TOKEN="degistir-mcp-icin-uzun-token"

# İlk admin kullanıcısı (seed bunu yazar)
ADMIN_EMAIL="merhaba@zerdemkartal.com"
ADMIN_PASSWORD="degistir"

# Google girişi (üretim) — id_token sunucuda doğrulanacak
GOOGLE_CLIENT_ID=""

# Site kökü (canonical/OG mutlak URL'ler)
SITE_URL="https://zerdemkartal.com"

# IndexNow anahtarı (opsiyonel — boşsa ping atlanır). Rastgele 32+ karakter hex önerilir;
# anahtar dosyası /indexnow.txt route'undan otomatik servis edilir.
INDEXNOW_KEY=""
